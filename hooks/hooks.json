{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/queue-next.sh",
            "statusMessage": "Checking queue..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/queue-stop.sh",
            "statusMessage": "Processing queue..."
          }
        ]
      }
    ]
  }
}
